# Copy to .env and fill in. Never commit .env. See the design notes.

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/fillerkiller?schema=public"

# TMDB v4 read access token (server-side only). See the design notes.
TMDB_API_READ_TOKEN=""

# TMDB image CDN base (no trailing slash).
TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"

# Auth.js session secret (generate with: openssl rand -base64 32).
AUTH_SECRET=""
