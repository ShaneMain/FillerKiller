// FillerKiller database schema.
// Mirrors the design notes in the internal docs repo. The catalog
// (Show/Season/Episode) is a cache of TMDB; Vote/EpisodeScore is the opinion
// layer we own. Keep this file in sync with the spec — changes there are
// spec changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VoteValue {
  FILLER
  CANON
}

model Show {
  id           String    @id @default(uuid())
  tmdbId       Int       @unique
  name         String
  firstAirYear Int?
  posterPath   String?
  overview     String?
  lastSyncedAt DateTime  @default(now())

  seasons  Season[]
  episodes Episode[]

  @@index([name])
}

model Season {
  id           String  @id @default(uuid())
  showId       String
  seasonNumber Int
  name         String?

  show     Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([showId, seasonNumber])
}

model Episode {
  id            String   @id @default(uuid())
  showId        String
  seasonId      String
  tmdbId        Int      @unique
  seasonNumber  Int
  episodeNumber Int
  name          String?
  overview      String?
  airDate       DateTime? @db.Date
  stillPath     String?

  show   Show         @relation(fields: [showId], references: [id], onDelete: Cascade)
  season Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  votes  Vote[]
  score  EpisodeScore?

  @@unique([showId, seasonNumber, episodeNumber])
  @@index([showId])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())

  votes Vote[]
}

model Vote {
  id        String    @id @default(uuid())
  userId    String
  episodeId String
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([episodeId])
}

// Cached aggregate per episode. In MVP this can be recomputed live; promote to
// a maintained table when read volume warrants. See the design notes.
model EpisodeScore {
  episodeId   String   @id
  fillerVotes Int      @default(0)
  canonVotes  Int      @default(0)
  fillerScore Float?
  updatedAt   DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}
