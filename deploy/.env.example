# Copy to deploy/.env and fill in. Never commit deploy/.env.
# Used by docker-compose.yml. See deploy/README.md and the design notes.

# Public domain (Caddy gets a TLS cert automatically). For a local test you can
# use localhost (Caddy serves an internal cert).
DOMAIN=fillerkiller.example.com

# --- Postgres (stays on the internal network; not exposed to the host) -------
POSTGRES_USER=fillerkiller
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=fillerkiller

# --- TMDB --------------------------------------------------------------------
TMDB_API_READ_TOKEN=
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# --- Auth ---------------------------------------------------------
# Generate: openssl rand -base64 32  (must be >= 32 bytes)
AUTH_JWT_SECRET=

# OAuth apps. Redirect URI to register: https://${DOMAIN}/api/auth/{provider}/callback
# A provider is disabled unless BOTH its id and secret are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
