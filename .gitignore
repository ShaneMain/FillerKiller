# Monorepo root. Each part (api/, web/) has its own .gitignore too.

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Env files (never commit real ones; *.example is allowed)
.env
*.env
!*.env.example

# Playwright MCP test artifacts
.playwright-mcp/

# Ad-hoc review screenshots dropped in the repo root (docs/ screenshots are tracked)
/*.png

# Local scratch / operational handoff notes (never publish — may hold infra IDs)
deploy/DOMAIN-CUTOVER-HANDOFF.md
