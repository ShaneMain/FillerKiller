{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT s.id, s.season_number, s.name, COUNT(e.id) AS \"episode_count!\"\n        FROM season s\n        LEFT JOIN episode e ON e.season_id = s.id\n        WHERE s.show_id = $1\n        GROUP BY s.id\n        ORDER BY s.season_number\n        ",
