{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT g.id, g.title, g.is_published, g.like_count::bigint AS \"like_count!\",\n               s.slug AS show_slug, s.name AS show_name\n        FROM skip_guide g\n        JOIN show s ON s.id = g.show_id\n        WHERE g.author_id = $1\n        ORDER BY g.is_published DESC, g.updated_at DESC\n        ",
