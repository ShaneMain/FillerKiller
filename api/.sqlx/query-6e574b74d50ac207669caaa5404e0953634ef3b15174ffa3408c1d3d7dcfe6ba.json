  "db_name": "PostgreSQL",
  "query": "\n        SELECT e.episode_id, ep.season_number, ep.episode_number, ep.name,\n               e.disposition::text AS \"disposition!\"\n        FROM skip_guide_entry e\n        JOIN episode ep ON ep.id = e.episode_id\n        WHERE e.guide_id = $1\n        ORDER BY ep.season_number, ep.episode_number\n        ",
