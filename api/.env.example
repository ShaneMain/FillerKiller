# Copy to api/.env and fill in. Never commit api/.env. See the design notes.

# Postgres connection string. For serverless Postgres (Neon/Supabase) use the
# POOLED connection string — see the design notes.
DATABASE_URL="postgresql://user:password@localhost:5432/fillerkiller"

# TMDB v4 read access token (server-side only). See the design notes.
TMDB_API_READ_TOKEN=""

# TMDB image CDN base (no trailing slash).
TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"

# Origin of the SPA, for CORS (the web/ dev server default is below).
CORS_ALLOWED_ORIGIN="http://localhost:5173"

# Address the API binds to. Ignored when PORT is set (Cloud Run and most
# serverless container hosts inject PORT, which then wins → 0.0.0.0:$PORT).
BIND_ADDR="0.0.0.0:8080"

# Apply migrations on boot. Default false: under ephemeral/multi-instance compute
# run the `migrate` subcommand as an explicit deploy step instead. A
# single-instance box can set this true for a one-command deploy.
RUN_MIGRATIONS_ON_BOOT="false"

# Max vote writes per client IP per minute.
VOTE_RATE_PER_MINUTE="30"

# --- Auth ---------------------------------

# HS256 signing secret for session JWTs. Generate: openssl rand -base64 32
AUTH_JWT_SECRET=""

# Public base URL of THIS API (used to build OAuth redirect URIs).
AUTH_BASE_URL="http://localhost:8080"

# Where to send the browser after a successful login (the SPA).
WEB_POST_LOGIN_URL="http://localhost:5173"

# Mark cookies Secure (true in prod over HTTPS; false for http dev).
AUTH_COOKIE_SECURE="false"

# OAuth provider apps. A provider is disabled unless BOTH its id and secret are
# set. Redirect URI to register: {AUTH_BASE_URL}/api/auth/{provider}/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
